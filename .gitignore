# ─── Python ─────────────────────────────────────────────────────────────────
# **/ 递归匹配任意层级的 __pycache__（root + pservice/api/ + skills/*/scripts/ 等）
**/__pycache__/
*.py[cod]
*.pyc
*.pyo
*.pyd             # PyInstaller 打包的 compiled extensions
*.egg-info/
*.egg

# PyInstaller
build/
dist/

# ─── Tauri / Frontend ───────────────────────────────────────────────────────
# Vite 构建产物（React 前端）
front/dist/

# Tauri 编译产物（Rust target + bundle）
front/src-tauri/target/

# ─── Node.js / npm ───────────────────────────────────────────────────────────
# 依赖由 package-lock.json 管理，node_modules 不入仓
front/node_modules/
pservice/node_modules/

# ─── OS ─────────────────────────────────────────────────────────────────────
.DS_Store
Thumbs.db
Desktop.ini

# ─── IDE ─────────────────────────────────────────────────────────────────────
.idea/
.vscode/
*.swp
*.swo

# ─── Temp / Logs ─────────────────────────────────────────────────────────────
*.log
build.log
build_error.log
