# ─── Python ─────────────────────────────────────────────────────────────────
# 字节码缓存（通配写法，不依赖 Python 版本）
__pycache__/
*.py[cod]
*.pyc

# PyInstaller
build/
dist/
*.spec

# 打包 / 启动脚本（由 build_launcher.py / launcher.py 自生成，不应入仓）
launcher.py
build_launcher.py

# ─── Node.js ────────────────────────────────────────────────────────────────
# 前端 add-in 依赖（由 npm install 生成，运行时由 CDN / 开发者环境提供）
word-addin/wordassistant/node_modules/

# webpack 构建产物（由 npm run build 生成，随 launcher 一起分发）
word-addin/wordassistant/dist/


/.idea